<Rung Number="1" Type="N">
<Text>
<![CDATA[SUB(DNSTRM,MSK,RES)EQ(RES,0)OTE(MODE);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(MODE)MOVE(0,tmr1.PRE);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(MC_RUN)[XIC(S_Mode) XIO(B2) XIC(B3) ,XIO(S_Mode) XIC(B2) XIO(B3) ]XIO(FLT)TON(tmr1,?,?);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[[XIC(tmr1.DN) XIC(ITL) OTL(MTR_OUT) ,XIC(MTR_PREV) XIC(MC_RUN) [XIC(S_Mode) XIC(B2) ,XIO(S_Mode) XIO(B2) ] ]OTL(MTR_CMD);]]>
