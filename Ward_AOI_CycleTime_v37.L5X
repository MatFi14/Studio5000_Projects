<Rung Number="6" Type="N">
<Text>
<![CDATA[[XIC(tmr2.DN) ,XIC(S_Mode) XIO(B3) OTU(MTR_OUT) XIO(MODE) ,XIO(S_Mode) XIC(B3) OTU(MTR_OUT) XIO(MODE) ,XIC(FLT) ,XIO(MC_RUN) ,[XIC(S_Mode) XIO(B2) XIO(B3) ,XIO(S_Mode) XIC(B2) XIC(B3) ] ,XIC(MTR_CMD) [XIC(S_Mode) XIO(B3) ,XIO(S_Mode) XIC(B3) ] XIC(MODE) TON(tmr3,?,?) XIC(tmr3.DN) ]OTU(MTR_CMD);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[XIC(RST)OTU(FLT);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[XIC(tmr2.DN)OTL(FLT);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[[XIC(S_Mode) XIO(B2) ,XIO(S_Mode) XIC(B2) ,XIC(MTR_OUT) ]TON(TMR4,?,?);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[XIC(TMR4.DN)OTE(BSY);]]>
</Text>
</Rung>
