<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[MOVE(tmr1PRE,tmr1.PRE)MOVE(tmr2PRE,tmr2.PRE)MOVE(tmr3PRE,tmr3.PRE);]]>
